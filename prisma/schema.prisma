generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model GithubRepo {
  id        String   @id @default(cuid())
  url       String   @unique
  data      Json
  fetchedAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
